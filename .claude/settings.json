{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "ocli hook tool-failure 2>/dev/null || true",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "ocli hook pre-compact 2>/dev/null || true",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "ocli hook session-start 2>/dev/null || true",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "ocli hook on-stop 2>/dev/null || true",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "ocli hook user-prompt 2>/dev/null || true",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}